index 00000000..56d6422e
--- /dev/null
+++ b/ready-to-run/D-stage/cpu-interface.md
@@ -0,0 +1,22 @@
+# CPU接口命名规范(D阶段)
+
+| | | | | | |
+| --- | --- | --- | --- | --- | --- |
+| CPU文件名 | | `ysyx_8位学号.v`          | 如`ysyx_23060000.v`   |
+| CPU顶层模块名 | | `ysyx_8位学号`        | 如`ysyx_23060000`     |
+| CPU内部模块名 | | `ysyx_8位学号_模块名` | 如`ysyx_23060000_ALU` |
+| 时钟 | input | `clock` |
+| 复位(高电平有效) | input | `reset` |
+| SimpleBus总线 |   |                     |
+| `output` |          | `io_ifu_pcValid`    |
+| `output` | `[31:0]` | `io_ifu_pc`         |
+| `input`  |          | `io_ifu_instValid`  |
+| `input`  | `[31:0]` | `io_ifu_inst`       |
+| `output` |          | `io_lsu_reqValid`   |
+| `output` | `[31:0]` | `io_lsu_addr`       |
+| `output` | `[1:0]`  | `io_lsu_size`       |
+| `output` |          | `io_lsu_wen`        |
+| `output` | `[31:0]` | `io_lsu_wdata`      |
+| `output` | `[3:0]`  | `io_lsu_wmask`      |
+| `input`  |          | `io_lsu_respValid`  |
+| `input`  | `[31:0]` | `io_lsu_rdata`      |
diff --git a/ready-to-run/D-stage/gen.sh b/ready-to-run/D-stage/gen.sh
new file mode 100644
index 00000000..34f5d96f
--- /dev/null
+++ b/ready-to-run/D-stage/gen.sh
@@ -0,0 +1,13 @@
+HELLO_BIN=hello-minirv-ysyxsoc.bin
+OUT_BIN=new.bin
+OFFSET=370432
+
+magic=`dd if=$HELLO_BIN bs=1 skip=$OFFSET count=4 | hexdump --format '"%x"'`
+
+if [[ $magic != "464c457f" ]]; then
+  echo bad magic number
+  exit -1
+fi
+
+cp $HELLO_BIN $OUT_BIN
+dd of=$OUT_BIN if=$1 bs=1 seek=$OFFSET
